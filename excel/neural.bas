Attribute VB_Name = "neural"
' -----------------------------------------------------------------------
' WAVELENGTH CALCULATOR (Neural-Network Surrogate)
' =====================================================================
' PURPOSE:
'   Computes wavelength using a trained feed-forward neural-network
'   surrogate built from the reference nonlinear wavelength database.
'
' PUBLIC ENTRY POINTS:
'   L_neural(H, T, d, Uc)
'   L(H, T, d, Uc)      ' Alias to L_neural
'
' INPUTS:
'   H  : Wave Height [m]
'   T  : Wave Period [s]
'   d  : Water Depth [m]
'   Uc : Current Velocity [m/s] (+ following, - opposing)
'
' RETURNS:
'   L_neural : Predicted wavelength [m]
'
' MODEL STRUCTURE:
'   1. Solve a linear Doppler baseline wavelength.
'   2. Build and normalise surrogate input features.
'   3. Evaluate the stored tanh-network weights and biases.
'   4. Transform network output back to physical wavelength.
'
' ROLE IN WORKBOOK:
'   High-capacity fast surrogate intended to reproduce nonlinear solver
'   behaviour with minimal runtime in spreadsheet environments.
' -----------------------------------------------------------------------

Private Const G As Double = 9.80665
Private Const PI As Double = 3.14159265358979
Private Const EPS_K As Double = 0.000000001
Private Const EPS_LOG As Double = 0.000000000001
Private Const Y_CLIP As Double = 2.5
Private Const HIDDEN_NEURONS As Long = 500
Private Const Y_MODE As String = "signedlog_ratio_minus1"

Private Const X0_MEAN As Double = 4.33124971462997E-02
Private Const X1_MEAN As Double = 15.3017404647378
Private Const X2_MEAN As Double = 1.06303761971906E-03
Private Const X0_STD As Double = 3.04551527953438E-02
Private Const X1_STD As Double = 51.549878300336
Private Const X2_STD As Double = 0.134500996492814
Private Const Y_MEAN As Double = 3.65620112228491E-02
Private Const Y_STD As Double = 7.61191937660805E-02

Private ModelReady As Boolean
Private W0() As Double
Private W1() As Double
Private W2() As Double
Private BHid() As Double
Private BetaH() As Double
Private BetaBias As Double

Public Function L_neural(ByVal H As Double, ByVal T As Double, _
                         ByVal d As Double, ByVal Uc As Double) As Double
    Dim L_lin As Double

    If T <= 0# Or d <= 0# Then
        L_neural = 0#
        Exit Function
    End If

    L_lin = SolveLinearDoppler(T, d, Uc)
    L_neural = PredictNN(H, T, d, Uc, L_lin)
End Function

Public Function L(ByVal H As Double, ByVal T As Double, _
                  ByVal d As Double, ByVal Uc As Double) As Double
    L = L_neural(H, T, d, Uc)
End Function

