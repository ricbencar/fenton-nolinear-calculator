    BetaH(498) = 4.7130475558535807E+01#
    BetaH(499) = -4.5649428940801940E+01#
    BetaBias = -1.0567898682940904E+03#

    ModelReady = True
End Sub

Private Function PredictNN(ByVal H As Double, ByVal T As Double, _
                           ByVal d As Double, ByVal Uc As Double, _
                           ByVal L_base As Double) As Double
    Dim x0_raw As Double, x1_raw As Double, x2_raw As Double
    Dim x0 As Double, x1 As Double, x2 As Double
    Dim acc As Double, y As Double, corr As Double
    Dim i As Long

    InitModel
    Call BuildSelectedFeatures(H, T, d, Uc, L_base, x0_raw, x1_raw, x2_raw)

    x0 = (x0_raw - X0_MEAN) / X0_STD
    x1 = (x1_raw - X1_MEAN) / X1_STD
    x2 = (x2_raw - X2_MEAN) / X2_STD

    acc = BetaBias
    For i = 0 To HIDDEN_NEURONS - 1
        acc = acc + BetaH(i) * FnTanh(BHid(i) + W0(i) * x0 + _
                                      W1(i) * x1 + W2(i) * x2)
    Next i

    y = Y_MEAN + Y_STD * acc

    Select Case Y_MODE
    Case "log_ratio"
        If y < -Y_CLIP Then y = -Y_CLIP
        If y > Y_CLIP Then y = Y_CLIP
        PredictNN = MaxVal(L_base, 0.1#) * Exp(y)

    Case "ratio_minus1"
        corr = 1# + y
        If corr <= 0.000000000001# Then corr = 0.000000000001#
        PredictNN = MaxVal(L_base, 0.1#) * corr

    Case "asinh_ratio_minus1"
        corr = 1# + FnSinh(y)
        If corr <= 0.000000000001# Then corr = 0.000000000001#
        PredictNN = MaxVal(L_base, 0.1#) * corr

    Case "signedlog_ratio_minus1"
        corr = 1# + SignedExpm1(y)
        If corr <= 0.000000000001# Then corr = 0.000000000001#
        PredictNN = MaxVal(L_base, 0.1#) * corr

    Case "k_ratio_minus1"
        corr = 1# + y
        If corr <= 0.000000000001# Then corr = 0.000000000001#
        PredictNN = MaxVal(L_base, 0.1#) / corr

    Case "asinh_k_ratio_minus1"
        corr = 1# + FnSinh(y)
        If corr <= 0.000000000001# Then corr = 0.000000000001#
        PredictNN = MaxVal(L_base, 0.1#) / corr

    Case "signedlog_k_ratio_minus1"
        corr = 1# + SignedExpm1(y)
        If corr <= 0.000000000001# Then corr = 0.000000000001#
        PredictNN = MaxVal(L_base, 0.1#) / corr

    Case Else
        PredictNN = MaxVal(L_base, 0.1#)
    End Select
End Function

Private Sub BuildSelectedFeatures(ByVal H As Double, ByVal T As Double, _
                                  ByVal d As Double, ByVal Uc As Double, _
                                  ByVal L_base As Double, _
                                  ByRef x0_raw As Double, _
                                  ByRef x1_raw As Double, _
                                  ByRef x2_raw As Double)
    Dim L_feat As Double
    Dim d_safe As Double
    Dim f(0 To 4) As Double

    L_feat = MaxVal(L_base, 0.1#)
    d_safe = MaxVal(d, 0.1#)
    f(0) = H / L_feat
    f(1) = d / L_feat
    f(2) = SignedLog1p((Uc * T) / L_feat)
    f(3) = (H * L_feat * L_feat) / (d_safe * d_safe * d_safe)
    f(4) = SignedLog1p(Uc / Sqr(G * d_safe))

    x0_raw = f(0)
    x1_raw = f(3)
    x2_raw = f(2)
End Sub

Private Function SolveLinearDoppler(ByVal T As Double, ByVal d As Double, _
                                    ByVal Uc As Double) As Double
    Dim omega As Double
    Dim k As Double
    Dim k_deep As Double
    Dim c_shallow As Double
    Dim k_shallow As Double
    Dim kd As Double
    Dim th As Double
    Dim sigma As Double
    Dim f As Double
    Dim sech2 As Double
    Dim d_sigma As Double
    Dim df As Double
    Dim k_new As Double
    Dim it As Long

    omega = 2# * PI / T
    k_deep = (omega * omega) / G
    c_shallow = Sqr(G * MaxVal(d, 0.000000000001#))
    k_shallow = omega / MaxVal(c_shallow, 0.000000000001#)

    If k_deep * d > 1# Then
        k = k_deep
    Else
        k = k_shallow
    End If

    For it = 1 To 8
        If k < EPS_K Then k = EPS_K
        If k > 400# Then k = 400#
        kd = k * d
        th = FnTanh(kd)
        sigma = Sqr(MaxVal(G * k * th, 0.0000000000000001#))
        f = sigma - omega
        sech2 = 1# - th * th
        If sigma > 0.000000000001# Then
            d_sigma = (G * th + G * kd * sech2) / (2# * sigma)
        Else
            d_sigma = 0#
        End If
        If Abs(d_sigma) < 0.000000000001# Then Exit For
        k_new = k - f / d_sigma
        If k_new <= EPS_K Then k_new = EPS_K
        k = 0.7# * k + 0.3# * k_new
    Next it

    For it = 1 To 40
        If k < EPS_K Then k = EPS_K
        If k > 400# Then k = 400#
        kd = k * d
        th = FnTanh(kd)
        sigma = Sqr(MaxVal(G * k * th, 0.0000000000000001#))
        f = sigma + k * Uc - omega
        sech2 = 1# - th * th
        If sigma > 0.000000000001# Then
            d_sigma = (G * th + G * kd * sech2) / (2# * sigma)
        Else
            d_sigma = 0#
        End If
        df = d_sigma + Uc
        If Abs(df) < 0.000000000001# Then Exit For
        k_new = k - f / df
        If k_new <= EPS_K Then k_new = EPS_K
        k = 0.8# * k + 0.2# * k_new
        If Abs(k_new - k) / MaxVal(k, EPS_K) < 0.0000000001# Then Exit For
    Next it

    If k <= EPS_K Then k = EPS_K
    SolveLinearDoppler = 2# * PI / k
End Function

Private Function MaxVal(ByVal a As Double, ByVal b As Double) As Double
    If a >= b Then
        MaxVal = a
    Else
        MaxVal = b
    End If
End Function

Private Function FnTanh(ByVal x As Double) As Double
    If x > 20# Then
        FnTanh = 1#
    ElseIf x < -20# Then
        FnTanh = -1#
    Else
        FnTanh = (Exp(x) - Exp(-x)) / (Exp(x) + Exp(-x))
    End If
End Function

Private Function FnSinh(ByVal x As Double) As Double
    FnSinh = 0.5# * (Exp(x) - Exp(-x))
End Function

Private Function FnAsinh(ByVal x As Double) As Double
    FnAsinh = Log(x + Sqr(x * x + 1#))
End Function

Private Function SignedLog1p(ByVal x As Double) As Double
    If x >= 0# Then
        SignedLog1p = Log(1# + x)
    Else
        SignedLog1p = -Log(1# + Abs(x))
    End If
End Function

Private Function SignedExpm1(ByVal x As Double) As Double
    If x >= 0# Then
        SignedExpm1 = Exp(x) - 1#
    Else
        SignedExpm1 = -(Exp(-x) - 1#)
    End If
End Function
