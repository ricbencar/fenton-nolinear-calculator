Public Function L_neural(ByVal H As Double, ByVal T As Double, _
                         ByVal d As Double, ByVal Uc As Double) As Double
    Dim L_lin As Double

    If T <= 0# Or d <= 0# Then
        L_neural = 0#
        Exit Function
    End If

    L_lin = SolveLinearDoppler(T, d, Uc)
    L_neural = PredictNN(H, T, d, Uc, L_lin)
End Function

Public Function L(ByVal H As Double, ByVal T As Double, _
                  ByVal d As Double, ByVal Uc As Double) As Double
